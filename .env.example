# ShipLog configuration
# Copy to .env and fill in your values.

# --- Required ---

# OpenAI-compatible API endpoint for LLM analysis
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=

# --- Optional ---

# LLM model (default: gcp/google/gemini-2.5-flash-lite)
# LLM_MODEL=gpt-4o-mini

# GitHub personal access token — raises rate limit from 60 to 5000 req/hr
# GITHUB_TOKEN=ghp_...

# SQLite database path (default: ~/.local/share/shiplog/shiplog.db)
# SHIPLOG_DB_PATH=

# --- Notifications (ntfy) ---
# Get started at https://ntfy.sh or self-host

# Topic name (required to enable notifications)
# NTFY_TOPIC=shiplog-updates

# ntfy server (default: https://ntfy.sh)
# NTFY_ENDPOINT=https://ntfy.sh

# Access token for private topics
# NTFY_TOKEN=

# Message priority 1-5 (default: 3)
# NTFY_PRIORITY=3
